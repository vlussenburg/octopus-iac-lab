# Secrets — stay local
.env
compose/license.xml
terraform.tfvars
secrets.auto.tfvars
*.secrets.tfvars
# Note: defaults.auto.tfvars and other non-sensitive *.auto.tfvars ARE
# committed — they hold lab-wide config like the Octopus URL.

# OpenTofu state — has secrets, machine-specific
*.tfstate
*.tfstate.*
.terraform/
crash.log
crash.*.log

# macOS
.DS_Store

# Note: .terraform.lock.hcl is intentionally NOT ignored — it pins provider
# versions and should be committed.
