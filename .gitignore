# Secrets — stay local
.env
compose/license.xml
terraform.tfvars
secrets.auto.tfvars
*.secrets.tfvars
# Note: defaults.auto.tfvars and other non-sensitive *.auto.tfvars ARE
# committed — they hold lab-wide config like the Octopus URL.

# OpenTofu state — has secrets, machine-specific
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log
crash.*.log

# macOS
.DS_Store
