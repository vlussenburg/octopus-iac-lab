# Copy to .env per worktree. Holds secrets + per-target URL only — non-sensitive
# lab config (CaC repo coords, agent settings) lives in committed
# `tofu/<stack>/defaults.auto.tfvars`.

# compose/docker-compose.yml — local self-host only. Ignored when targeting SaaS.
# MASTER_KEY encrypts the Octopus database. Generate once, never change after
# first boot or you'll lose access to encrypted data.
#   openssl rand -base64 16
MASTER_KEY=CHANGE_ME

# tofu/ — exported by the Makefile as TF_VAR_octopus_url, TF_VAR_octopus_api_key,
# TF_VAR_github_pat. OCTOPUS_URL switches the worktree between local and SaaS:
#   local: http://localhost:8090
#   SaaS:  https://<your-instance-id>.octopus.app
OCTOPUS_URL=http://localhost:8090
OCTOPUS_API_KEY=API-XXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
