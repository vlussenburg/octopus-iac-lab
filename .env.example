# Copy to .env. Holds secrets only — non-sensitive lab config (Octopus URL,
# space, CaC repo, etc.) lives in committed `tofu/<stack>/defaults.auto.tfvars`.

# compose/docker-compose.yml
# MASTER_KEY encrypts the Octopus database. Generate once, never change after
# first boot or you'll lose access to encrypted data.
#   openssl rand -base64 16
MASTER_KEY=CHANGE_ME

# tofu/ — exported by the Makefile as TF_VAR_octopus_api_key and TF_VAR_github_pat
OCTOPUS_API_KEY=API-XXXXXXXXXXXXXXXXXXXXXXXXX
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
