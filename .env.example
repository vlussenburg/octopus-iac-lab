# Copy to .env. Loaded by the Makefile, by `docker compose --env-file .env`,
# and exported into Terraform as TF_VAR_*.

# === compose/docker-compose.yml ===
# MASTER_KEY encrypts the Octopus database. Generate once, never change after first boot
# or you'll lose access to encrypted data. Generate with:
#   openssl rand -base64 16
MASTER_KEY=CHANGE_ME

# === Octopus API (terraform/) ===
OCTOPUS_URL=http://localhost:8090
# Space *ID* (not name). Default install ships with Spaces-1.
OCTOPUS_SPACE=Spaces-1

# API key minted in Octopus UI: Profile -> My API Keys.
OCTOPUS_API_KEY=API-XXXXXXXXXXXXXXXXXXXXXXXXX

# GitHub PAT used by Octopus to read/write OCL in cac/. Needs `repo` scope.
GITHUB_PAT=ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# URL Octopus pulls/pushes CaC OCL from. Point at this repo once it's on GitHub.
CAC_REPO_URL=https://github.com/vlussenburg/octopus-iac-lab.git
CAC_BRANCH=main
# Octopus enforces this — must be .octopus (server rejects anything else).
CAC_BASE_PATH=.octopus
